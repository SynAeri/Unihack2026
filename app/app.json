{
  "expo": {
    "name": "Compass",
    "slug": "Compass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "compass",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Compass",
      "appleTeamId": "D7MJ6X2TMM"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Compass"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "@reactvision/react-viro",
        {
          "android": {
            "xRMode": ["AR"]
          },
          "ios": {
            "NSCameraUsageDescription": "Camera is used for augmented reality features.",
            "NSMicrophoneUsageDescription": "Microphone access is required for AR interactions.",
            "NSPhotoLibraryUsageDescription": "Photo library access is needed to save AR content.",
            "NSPhotoLibraryAddUsageDescription": "Permission to save photos from the app."
          }
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Compass needs access to your camera to detect objects.",
          "enableMicrophonePermission": false,
          "enableLocationPermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
